int lo1
    ip addr 10.7.7.105 255.255.255.255
exit

router ospf 100
    network 192.168.101.0 0.0.0.255 area 0   ! Tunnel-Netz 101
    network 192.168.102.0 0.0.0.255 area 0   ! Tunnel-Netz 101
    network 10.7.7.5 0.0.0.0 area 0          ! eigene Loopback
    network 10.7.7.105 0.0.0.0 area 0        ! Loopback für BGP und L3VPN
exit

! ACHTUNG: IS-IS advertized ebenfalls 10.7.7.x (loopbacks)
! Aber: OSPF gewinnt


! -- VRFs --

mpls ldp router-id Loopback0 force

int tun 101
    mpls ip
exit
int tun 102
    mpls ip
exit

ip vrf VIE
    rd 65007:10
    route-target export 65007:10
    route-target import 65007:10
exit

ip vrf OOE
    rd 65007:20
    route-target export 65007:20
    route-target import 65007:20
exit

ip vrf ZWG
    rd 65007:30
    route-target export 65007:30
    route-target import 65007:30
exit



int g0/1
    ip vrf forwarding OOE
    ip address 172.16.8.1 255.255.255.0
    no shutdown
exit
int g0/2
    ip vrf forwarding ZWG
    ip address 172.16.14.254 255.255.255.0
    no shutdown
exit

! --- BGP ---

router bgp 65007
    bgp router-id 10.7.7.105
    no bgp default ipv4-unicast

    neighbor 10.7.7.101 remote-as 65007
    neighbor 10.7.7.101 update-source lo1
    neighbor 10.7.7.102 remote-as 65007
    neighbor 10.7.7.102 update-source lo1
    neighbor 10.7.7.103 remote-as 65007
    neighbor 10.7.7.103 update-source lo1
    neighbor 10.7.7.104 remote-as 65007
    neighbor 10.7.7.104 update-source lo1

    address-family vpnv4
        neighbor 10.7.7.101 activate
        neighbor 10.7.7.101 send-community extended
        neighbor 10.7.7.102 activate
        neighbor 10.7.7.102 send-community extended
        neighbor 10.7.7.103 activate
        neighbor 10.7.7.103 send-community extended
        neighbor 10.7.7.104 activate
        neighbor 10.7.7.104 send-community extended
    exit-address-family

    ! OOE CE:
    address-family ipv4 vrf OOE
        neighbor 172.16.8.2 remote-as 65020
        neighbor 172.16.8.2 activate
    exit-address-family

    ! ZWG CE – eigene VRF, komplett isoliert von OOE:
    address-family ipv4 vrf ZWG
        neighbor 172.16.14.2 remote-as 65030
        neighbor 172.16.14.2 activate
    exit-address-family
exit

