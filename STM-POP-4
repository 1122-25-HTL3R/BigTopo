int lo1
    ip addr 10.7.7.104 255.255.255.255
exit

router ospf 100
    network 192.168.101.0 0.0.0.255 area 0   ! Tunnel-Netz 101
    network 192.168.102.0 0.0.0.255 area 0   ! Tunnel-Netz 101
    network 10.7.7.4 0.0.0.0 area 0          ! eigene Loopback
    network 10.7.7.104 0.0.0.0 area 0        ! Loopback für BGP und L3VPN
exit


! -- VRFs --

mpls ldp router-id Loopback0 force

int tun 101
    mpls ip
exit
int tun 102
    mpls ip
exit

ip vrf VIE
    rd 65007:10
    route-target export 65007:10
    route-target import 65007:10
exit

ip vrf OOE
    rd 65007:20
    route-target export 65007:20
    route-target import 65007:20
exit

ip vrf ZWG
    rd 65007:30
    route-target export 65007:30
    route-target import 65007:30
exit


int g0/0
    ip vrf forwarding OOE
    ip address 172.16.9.1 255.255.255.0
    no shutdown
exit


! --- BGP ---

router bgp 65007
    bgp router-id 10.7.7.4
    no bgp default ipv4-unicast

    neighbor 10.7.7.101 remote-as 65007
    neighbor 10.7.7.101 update-source lo0
    neighbor 10.7.7.102 remote-as 65007
    neighbor 10.7.7.102 update-source lo0
    neighbor 10.7.7.103 remote-as 65007
    neighbor 10.7.7.103 update-source lo0
    neighbor 10.7.7.105 remote-as 65007
    neighbor 10.7.7.105 update-source lo0

    address-family vpnv4
        neighbor 10.7.7.101 activate
        neighbor 10.7.7.101 send-community extended
        neighbor 10.7.7.102 activate
        neighbor 10.7.7.102 send-community extended
        neighbor 10.7.7.103 activate
        neighbor 10.7.7.103 send-community extended
        neighbor 10.7.7.105 activate
        neighbor 10.7.7.105 send-community extended
    exit-address-family

    address-family ipv4 vrf OOE
        neighbor 172.16.9.2 remote-as 65020
        neighbor 172.16.9.2 activate
    exit-address-family
exit