! BigTopo
! VIE-POP-3

en
conf t
hostname VIE-POP-3
no ip domain lookup
service password-encr


ip domain name BigTopo
ip ssh version 2
crypto key gen rsa usage-k mod 2048

username cisco priv 15
username cisco algorithm-type scrypt secret cisco

line vty 0 97
login local
logging sync
exec-timeout 0 0
transport input ssh telnet
exit


interface gig0/0
description Connection to STM-POP-2
ip address 172.16.4.1 255.255.255.0
no shutdown
exit





router bgp 3
    bgp router-id 172.16.4.1
    neighbor 172.16.4.2 remote-as 4
    
    address-family ipv4
        neighbor 172.16.4.2 activate
        network 172.16.4.0 mask 255.255.255.0
    exit-address-family
exit


router bgp 3
    address-family ipv4
        neighbor 172.16.4.2 allowas-in
    exit-address-family
exit