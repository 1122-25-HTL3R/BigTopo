router ospf 100
    network 192.168.100.0 0.0.0.255 area 0   ! Tunnel-Netz
    network 10.7.7.3 0.0.0.0 area 0          ! eigene Loopback
exit


! -- VRFs --

mpls ldp router-id Loopback0 force

int tun 100
    mpls ip
exit

ip vrf VIE
    rd 65007:10
    route-target export 65007:10
    route-target import 65007:10
exit

ip vrf OOE
    rd 65007:20
    route-target export 65007:20
    route-target import 65007:20
exit

ip vrf ZWG
    rd 65007:30
    route-target export 65007:30
    route-target import 65007:30
exit


int g0/0
    ip vrf forwarding OOE
    ip address 172.16.10.1 255.255.255.0
    no shutdown
exit



! --- BGP ---

router bgp 65007
    bgp router-id 10.7.7.3
    no bgp default ipv4-unicast

    neighbor 10.7.7.1 remote-as 65007
    neighbor 10.7.7.1 update-source lo0
    neighbor 10.7.7.2 remote-as 65007
    neighbor 10.7.7.2 update-source lo0
    neighbor 10.7.7.4 remote-as 65007
    neighbor 10.7.7.4 update-source lo0
    neighbor 10.7.7.5 remote-as 65007
    neighbor 10.7.7.5 update-source lo0

    address-family vpnv4
        neighbor 10.7.7.1 activate
        neighbor 10.7.7.1 send-community extended
        neighbor 10.7.7.2 activate
        neighbor 10.7.7.2 send-community extended
        neighbor 10.7.7.4 activate
        neighbor 10.7.7.4 send-community extended
        neighbor 10.7.7.5 activate
        neighbor 10.7.7.5 send-community extended
    exit-address-family

    address-family ipv4 vrf OOE
        neighbor 172.16.10.2 remote-as 65020
        neighbor 172.16.10.2 activate
    exit-address-family
exit

