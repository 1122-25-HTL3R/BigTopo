! BigTopo
! STM-POP-3

en
conf t
hostname STM-POP-3
no ip domain lookup
service password-encr


ip domain name BigTopo
ip ssh version 2
crypto key gen rsa usage-k mod 2048

username cisco priv 15
username cisco algorithm-type scrypt secret cisco

line vty 0 97
login local
logging sync
exec-timeout 0 0
transport input ssh telnet
exit


interface gig0/0
description Connection to OOE-POP-2
ip address 172.16.10.1 255.255.255.0
no shutdown

interface gig0/1
description Connection to SZB-R-2
ip address 10.7.0.10 255.255.255.252
no shutdown
exit


int lo0
    ip addr 10.7.7.3 255.255.255.255
exit

! IS-IS
router isis
	no passive-interface default
    passive-interface lo0 ! lo0 ausnahme: advertise aber kein Hello
exit
int range g0/1,lo0
	ip router isis
exit
router isis
	no passive-interface g0/1

	! lo0 10.7.7.3 -> 010 007 007 003
	! -> 0100.0700.7003
	net 49.0001.0100.0700.7003.00
exit
do show clns neigh



! --- DMVPN ---

! Spoke für Hub1
int tun 101
    ip address 192.168.101.3 255.255.255.0
    tunnel source lo0
    tunnel destination 10.7.7.1         

    ip nhrp authentication DMVPN
    ip nhrp network-id 101
    ip nhrp nhs 192.168.101.1
    
    ip ospf priority 0
    ip ospf network point-to-multipoint
    ip ospf 100 area 0
    mpls ip

    # later!!! tun protection ipsec profile DMVPN
exit

! Spoke für Hub2
int tun 102
    ip address 192.168.102.3 255.255.255.0
    tunnel source lo0
    tunnel destination 10.7.7.2          
    
    ip nhrp authentication DMVPN
    ip nhrp network-id 102
    ip nhrp nhs 192.168.102.1
    
    ip ospf priority 0
    ip ospf network point-to-multipoint
    ip ospf 100 area 0
    mpls ip

    # later!!! tun protection ipsec profile DMVPN
exit


int lo1
    ip addr 10.7.7.103 255.255.255.255
exit

router ospf 100
    router-id 10.7.7.103
    network 192.168.101.0 0.0.0.255 area 0   ! Tunnel-Netz 101
    network 192.168.102.0 0.0.0.255 area 0   ! Tunnel-Netz 101
    ! # network 10.7.7.3 0.0.0.0 area 0          ! eigene Loopback na ned für BGP
    network 10.7.7.103 0.0.0.0 area 0        ! Loopback für BGP und L3VPN
exit


! -- VRFs --

mpls ldp router-id Loopback1 force

int tun 101
    mpls ip
exit
int tun 102
    mpls ip
exit


